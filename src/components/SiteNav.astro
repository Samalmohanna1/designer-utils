---
// Top nav shared across the tool pages. `active` marks the current tool so its
// link reads as selected. Add new tools here as the suite grows.
interface Props {
	active: 'color' | 'type' | 'space' | 'foundations' | 'export'
}
const { active } = Astro.props

// FontAwesome solid paths (viewBox 0 0 512 512): palette for the color tool,
// a typography "T" for the type tool, a combined ruler for space/grid,
// stacked layers for foundations, and a download tray for export.
const icons: Record<Props['active'], string> = {
	color: 'M204.3 5C104.9 24.4 24.8 104.3 5.2 203.4c-37 187 131.7 326.4 258.8 306.7 41.2-6.4 61.4-54.6 42.5-91.7-23.1-45.4 9.9-98.4 60.9-98.4l79.7 0c35.8 0 64.8-29.6 64.9-65.3C511.5 97.1 368.1-26.9 204.3 5zM96 320a32 32 0 1 1 0-64 32 32 0 1 1 0 64zm32-128a32 32 0 1 1 -64 0 32 32 0 1 1 64 0zm128-64a32 32 0 1 1 0-64 32 32 0 1 1 0 64zm128 64a32 32 0 1 1 -64 0 32 32 0 1 1 64 0z',
	type: 'M254 52.8C249.3 40.3 237.3 32 224 32s-25.3 8.3-30 20.8L57.8 416 32 416c-17.7 0-32 14.3-32 32s14.3 32 32 32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-3.1 0 18-48 152.2 0 18 48-3.1 0c-17.7 0-32 14.3-32 32s14.3 32 32 32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-25.8 0L254 52.8zM279.8 304l-111.6 0L224 155.1 279.8 304z',
	space: 'M.2 468.9C2.7 493.1 23.1 512 47.9 512l16.1 0 0-96c0-17.7 14.3-32 32-32s32 14.3 32 32l0 96 64 0 0-96c0-17.7 14.3-32 32-32s32 14.3 32 32l0 96 64 0 0-96c0-17.7 14.3-32 32-32s32 14.3 32 32l0 96 16.1 0c24.8 0 45.2-18.9 47.7-43.1 .2-1.6 .2-3.2 .2-4.9l0-320c0-26.5-21.5-48-48-48L48 96C21.5 96 0 117.5 0 144l0 320c0 1.6 .1 3.3 .2 4.9z',
	foundations: 'M232.5 5.2c15-7 32.1-7 47.1 0l211.9 98.3c7.6 3.5 12.5 11.2 12.5 19.6s-4.9 16.1-12.5 19.6L279.5 241c-15 7-32.1 7-47.1 0L20.5 142.7C12.9 139.2 8 131.5 8 123.1s4.9-16.1 12.5-19.6L232.5 5.2zM73.1 292.7l159.4 73.9c15 7 32.1 7 47.1 0l159.4-73.9 52.5 24.4c7.6 3.5 12.5 11.2 12.5 19.6s-4.9 16.1-12.5 19.6L279.5 454.5c-15 7-32.1 7-47.1 0L20.5 356.3C12.9 352.8 8 345.1 8 336.7s4.9-16.1 12.5-19.6l52.6-24.4z',
	'export': 'M288 32c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 242.7-73.4-73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l128 128c12.5 12.5 32.8 12.5 45.3 0l128-128c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L288 274.7 288 32zM64 352c-35.3 0-64 28.7-64 64l0 32c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-32c0-35.3-28.7-64-64-64l-101.5 0-45.3 45.3c-25 25-65.5 25-90.5 0L165.5 352 64 352zm368 56a24 24 0 1 1 0 48 24 24 0 1 1 0-48z',
}

const links: {
	href: string
	label: string
	key: Props['active']
}[] = [
	{ href: '/', label: 'Color Scales', key: 'color' },
	{ href: '/type', label: 'Type Scales', key: 'type' },
	{ href: '/space', label: 'Space & Grid', key: 'space' },
	{ href: '/foundations', label: 'Foundations', key: 'foundations' },
	{ href: '/export', label: 'Export', key: 'export' },
]
---

<nav
	aria-label='Tools'
	class='mx-auto px-s py-2xs bg-cream-100 rounded-b-md shadow-xs container mb-m'
>
	<ul class='flex flex-wrap gap-2xs'>
		{
			links.map(({ href, label, key }) => (
				<li>
					<a
						href={href}
						aria-current={active === key ? 'page' : undefined}
						class:list={[
							'inline-flex items-center gap-2xs px-xs py-3xs rounded-sm font-roboto-condensed font-bold uppercase text-step--2 tracking-tight',
							active === key
								? 'bg-black-500 text-cream-100'
								: 'border border-black-100 hover:bg-black-500 hover:text-cream-100',
						]}
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 512 512'
							class='w-3.5 h-3.5 fill-current shrink-0'
							aria-hidden='true'
						>
							<path d={icons[key]} />
						</svg>
						{label}
					</a>
				</li>
			))
		}
	</ul>
</nav>
