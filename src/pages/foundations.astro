---
import Layout from '../layouts/Layout.astro'
import SiteNav from '../components/SiteNav.astro'
import SiteFooter from '../components/SiteFooter.astro'
import Foundations from '../components/Foundations'
---

<Layout
	title='Design System Foundations | MYOL Creative'
	description='Generate corner radii, border widths, elevation shadows, font stacks, and motion tokens — then export your whole design system as CSS, Tailwind 4, or W3C Design Tokens.'
	path='/foundations'
	image='/og-foundations.png'
>
	<SiteNav active='foundations' />
	<main class='mx-auto p-s bg-cream-100 rounded-md shadow-xs container'>
		<Foundations client:load />
	</main>
	<SiteFooter />
</Layout>
