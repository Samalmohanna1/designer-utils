---
import Layout from '../layouts/Layout.astro'

// The suite now lives on one page; this route survives for old links and
// social shares (the OG card). The redirect keeps any legacy #s= hash.
---

<Layout
	title='Space & Grid Calculator | MYOL Creative'
	description='Build a fluid spacing scale and layout grid with CSS clamp(). Set min and max viewport and base size, preview T-shirt sizes and pairs on an 8pt grid, configure a column grid, and copy the CSS.'
	path='/space'
	image='/og-space.png'
>
	<script is:inline>
		location.replace('/?go=space' + location.hash)
	</script>
	<main class='mx-auto p-s bg-cream-100 rounded-md shadow-xs container'>
		<p>
			The Space &amp; Grid tool moved to the main page.
			<a href='/?go=space' class='underline font-bold'>Continue to the Space &amp; Grid section</a>.
		</p>
	</main>
</Layout>
